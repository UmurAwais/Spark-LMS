# MongoDB Connection
# For MongoDB Atlas (Cloud):
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/spark-lms?retryWrites=true&w=majority

# For Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/spark-lms

# Admin Password
ADMIN_PASSWORD=your-secure-admin-password-here

# Server Port
PORT=4001
